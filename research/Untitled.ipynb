    "import os\n",
    "import cv2\n",
    "import random\n",
    "import numpy as np\n",
    "from tqdm import tqdm\n",
    "\n",
    "WEED_DIR = \"../artifacts/data_ingestion/normalized/v_20260307_192121_5a0b6671da93a189/organized_by_species/train/deepweeds\"\n",
    "BACKGROUND_DIR = \"../artifacts/data_ingestion/normalized/v_20260307_192121_5a0b6671da93a189/organized_by_species/train/backgrounds\"\n",
    "\n",
    "OUT_IMG = \"../artifacts/data_ingestion/normalized/v_20260307_192121_5a0b6671da93a189/organized_by_species/train/output/images\"\n",
    "OUT_LABEL = \"../artifacts/data_ingestion/normalized/v_20260307_192121_5a0b6671da93a189/organized_by_species/train/output/labels\"\n",
    "\n",
    "IMG_SIZE = 640\n",
    "\n",
    "os.makedirs(OUT_IMG, exist_ok=True)\n",
    "os.makedirs(OUT_LABEL, exist_ok=True)\n",
    "\n",
    "\n",
    "def load_weeds():\n",
    "    weeds = []\n",
    "\n",
    "    for label, cls in enumerate(os.listdir(WEED_DIR)):\n",
    "        class_path = os.path.join(WEED_DIR, cls)\n",
    "\n",
    "        for img in os.listdir(class_path):\n",
    "            path = os.path.join(class_path, img)\n",
    "\n",
    "            weed = cv2.imread(path)\n",
    "\n",
    "            if weed is not None:\n",
    "                weeds.append((weed, label))\n",
    "\n",
    "    return weeds\n",
    "\n",
    "\n",
    "def load_backgrounds():\n",
    "\n",
    "    bgs = []\n",
    "\n",
    "    for img in os.listdir(BACKGROUND_DIR):\n",
    "        path = os.path.join(BACKGROUND_DIR, img)\n",
    "\n",
    "        bg = cv2.imread(path)\n",
    "\n",
    "        if bg is not None:\n",
    "            bg = cv2.resize(bg, (IMG_SIZE, IMG_SIZE))\n",
    "            bgs.append(bg)\n",
    "\n",
    "    return bgs\n",
    "\n",
    "\n",
    "def augment_weed(weed):\n",
    "\n",
    "    scale = random.uniform(0.4, 1.2)\n",
    "\n",
    "    h, w = weed.shape[:2]\n",
    "\n",
    "    weed = cv2.resize(weed, (int(w * scale), int(h * scale)))\n",
    "\n",
    "    angle = random.randint(-30, 30)\n",
    "\n",
    "    M = cv2.getRotationMatrix2D(\n",
    "        (weed.shape[1] // 2, weed.shape[0] // 2), angle, 1\n",
    "    )\n",
    "\n",
    "    weed = cv2.warpAffine(\n",
    "        weed,\n",
    "        M,\n",
    "        (weed.shape[1], weed.shape[0]),\n",
    "        borderValue=(0, 0, 0),\n",
    "    )\n",
    "\n",
    "    return weed\n",
    "\n",
    "\n",
    "def paste_weed(bg, weed):\n",
    "\n",
    "    h, w = weed.shape[:2]\n",
    "\n",
    "    x = random.randint(0, IMG_SIZE - w)\n",
    "    y = random.randint(0, IMG_SIZE - h)\n",
    "\n",
    "    roi = bg[y : y + h, x : x + w]\n",
    "\n",
    "    gray = cv2.cvtColor(weed, cv2.COLOR_BGR2GRAY)\n",
    "\n",
    "    _, mask = cv2.threshold(gray, 10, 255, cv2.THRESH_BINARY)\n",
    "\n",
    "    mask_inv = cv2.bitwise_not(mask)\n",
    "\n",
    "    bg_roi = cv2.bitwise_and(roi, roi, mask=mask_inv)\n",
    "\n",
    "    weed_fg = cv2.bitwise_and(weed, weed, mask=mask)\n",
    "\n",
    "    dst = cv2.add(bg_roi, weed_fg)\n",
    "\n",
    "    bg[y : y + h, x : x + w] = dst\n",
    "\n",
    "    return bg, x, y, w, h\n",
    "\n",
    "\n",
    "def to_yolo(x, y, w, h):\n",
    "\n",
    "    x_center = (x + w / 2) / IMG_SIZE\n",
    "    y_center = (y + h / 2) / IMG_SIZE\n",
    "\n",
    "    w /= IMG_SIZE\n",
    "    h /= IMG_SIZE\n",
    "\n",
    "    return x_center, y_center, w, h\n",
    "\n",
    "\n",
    "def generate_dataset(num_images=5000):\n",
    "\n",
    "    weeds = load_weeds()\n",
    "    bgs = load_backgrounds()\n",
    "\n",
    "    for i in tqdm(range(num_images)):\n",
    "\n",
    "        bg = random.choice(bgs).copy()\n",
    "\n",
    "        num_weeds = random.randint(2, 8)\n",
    "\n",
    "        labels = []\n",
    "\n",
    "        for _ in range(num_weeds):\n",
    "\n",
    "            weed, cls = random.choice(weeds)\n",
    "\n",
    "            weed = augment_weed(weed)\n",
    "\n",
    "            bg, x, y, w, h = paste_weed(bg, weed)\n",
    "\n",
    "            x, y, w, h = to_yolo(x, y, w, h)\n",
    "\n",
    "            labels.append(f\"{cls} {x} {y} {w} {h}\")\n",
    "\n",
    "        img_name = f\"img_{i}.jpg\"\n",
    "\n",
    "        cv2.imwrite(os.path.join(OUT_IMG, img_name), bg)\n",
    "\n",
    "        with open(\n",
    "            os.path.join(OUT_LABEL, img_name.replace(\".jpg\", \".txt\")), \"w\"\n",
    "        ) as f:\n",
    "\n",
    "            f.write(\"\\n\".join(labels))\n",
    "\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "\n",
    "    generate_dataset(10000)"
   ]
  },
