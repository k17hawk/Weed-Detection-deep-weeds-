    "import os\n",
    "import cv2\n",
    "import random\n",
    "import numpy as np\n",
    "from tqdm import tqdm\n",
    "\n",
    "# Path to Chinese apple images only\n",
    "CHINEE_APPLE_DIR = \"../artifacts/data_ingestion/normalized/v_20260307_192121_5a0b6671da93a189/organized_by_species/train/deepweeds/Chinee Apple\" \n",
    "BACKGROUND_DIR = \"../artifacts/data_ingestion/normalized/v_20260307_192121_5a0b6671da93a189/organized_by_species/train/backgrounds\"\n",
    "\n",
    "OUT_IMG = \"../artifacts/data_ingestion/normalized/v_20260307_192121_5a0b6671da93a189/organized_by_species/train/output/images\"\n",
    "OUT_LABEL = \"../artifacts/data_ingestion/normalized/v_20260307_192121_5a0b6671da93a189/organized_by_species/train/output/labels\"\n",
    "\n",
    "IMG_SIZE = 640\n",
    "\n",
    "os.makedirs(OUT_IMG, exist_ok=True)\n",
    "os.makedirs(OUT_LABEL, exist_ok=True)\n",
    "\n",
    "\n",
    "def load_chinee_apple_images():\n",
    "    \"\"\"\n",
    "    Load only Chinese apple images from the specified directory\n",
    "    \"\"\"\n",
    "    chinee_apple_images = []\n",
    "    \n",
    "    # If you want to use a specific class folder\n",
    "    if os.path.exists(CHINEE_APPLE_DIR):\n",
    "        for img in os.listdir(CHINEE_APPLE_DIR):\n",
    "            path = os.path.join(CHINEE_APPLE_DIR, img)\n",
    "            weed = cv2.imread(path)\n",
    "            if weed is not None:\n",
    "                chinee_apple_images.append((weed, 0))  # Class 0 for Chinese apple\n",
    "    \n",
    "    # Alternative: If Chinese apple is a specific class in the deepweeds folder structure\n",
    "    # and you know its class index (e.g., class 2), you can use this:\n",
    "    \"\"\"\n",
    "    for label, cls in enumerate(os.listdir(WEED_DIR)):\n",
    "        if cls.lower() in ['chinense_apple', 'chinese_apple', 'chine_apple']:  # Adjust based on your folder name\n",
    "            class_path = os.path.join(WEED_DIR, cls)\n",
    "            for img in os.listdir(class_path):\n",
    "                path = os.path.join(class_path, img)\n",
    "                weed = cv2.imread(path)\n",
    "                if weed is not None:\n",
    "                    chinee_apple_images.append((weed, 0))  # Use 0 as class ID\n",
    "    \"\"\"\n",
    "    \n",
    "    print(f\"Loaded {len(chinee_apple_images)} Chinese apple images\")\n",
    "    return chinee_apple_images\n",
    "\n",
    "\n",
    "def load_backgrounds():\n",
    "    \"\"\"\n",
    "    Load background images\n",
    "    \"\"\"\n",
    "    bgs = []\n",
    "    for img in os.listdir(BACKGROUND_DIR):\n",
    "        path = os.path.join(BACKGROUND_DIR, img)\n",
    "        bg = cv2.imread(path)\n",
    "        if bg is not None:\n",
    "            bg = cv2.resize(bg, (IMG_SIZE, IMG_SIZE))\n",
    "            bgs.append(bg)\n",
    "    \n",
    "    print(f\"Loaded {len(bgs)} background images\")\n",
    "    return bgs\n",
    "\n",
    "\n",
    "def augment_weed(weed):\n",
    "    \"\"\"\n",
    "    Apply random augmentations to the weed image\n",
    "    \"\"\"\n",
    "    # Random scaling\n",
    "    scale = random.uniform(0.4, 1.2)\n",
    "    h, w = weed.shape[:2]\n",
    "    weed = cv2.resize(weed, (int(w * scale), int(h * scale)))\n",
    "    \n",
    "    # Random rotation\n",
    "    angle = random.randint(-30, 30)\n",
    "    M = cv2.getRotationMatrix2D(\n",
    "        (weed.shape[1] // 2, weed.shape[0] // 2), angle, 1\n",
    "    )\n",
    "    weed = cv2.warpAffine(\n",
    "        weed,\n",
    "        M,\n",
    "        (weed.shape[1], weed.shape[0]),\n",
    "        borderValue=(0, 0, 0),\n",
    "    )\n",
    "    \n",
    "    # Optional: Add random brightness/contrast adjustments\n",
    "    if random.random() > 0.5:\n",
    "        alpha = random.uniform(0.8, 1.2)  # Contrast\n",
    "        beta = random.randint(-20, 20)     # Brightness\n",
    "        weed = cv2.convertScaleAbs(weed, alpha=alpha, beta=beta)\n",
    "    \n",
    "    return weed\n",
    "\n",
    "\n",
    "def paste_weed(bg, weed):\n",
    "    \"\"\"\n",
    "    Paste weed onto background with proper masking\n",
    "    \"\"\"\n",
    "    h, w = weed.shape[:2]\n",
    "    \n",
    "    # Ensure weed fits within background\n",
    "    if h > IMG_SIZE or w > IMG_SIZE:\n",
    "        scale = min(IMG_SIZE / h, IMG_SIZE / w) * 0.8\n",
    "        new_h, new_w = int(h * scale), int(w * scale)\n",
    "        weed = cv2.resize(weed, (new_w, new_h))\n",
    "        h, w = new_h, new_w\n",
    "    \n",
    "    # Random position\n",
    "    x = random.randint(0, max(0, IMG_SIZE - w))\n",
    "    y = random.randint(0, max(0, IMG_SIZE - h))\n",
    "    \n",
    "    # Extract region of interest\n",
    "    roi = bg[y:y + h, x:x + w]\n",
    "    \n",
    "    # Create mask from weed (assuming weed has non-black background)\n",
    "    gray = cv2.cvtColor(weed, cv2.COLOR_BGR2GRAY)\n",
    "    _, mask = cv2.threshold(gray, 10, 255, cv2.THRESH_BINARY)\n",
    "    mask_inv = cv2.bitwise_not(mask)\n",
    "    \n",
    "    # Black-out the area of weed in ROI\n",
    "    bg_roi = cv2.bitwise_and(roi, roi, mask=mask_inv)\n",
    "    \n",
    "    # Take only region of weed from weed image\n",
    "    weed_fg = cv2.bitwise_and(weed, weed, mask=mask)\n",
    "    \n",
    "    # Put weed in ROI and modify the background\n",
    "    dst = cv2.add(bg_roi, weed_fg)\n",
    "    bg[y:y + h, x:x + w] = dst\n",
    "    \n",
    "    return bg, x, y, w, h\n",
    "\n",
    "\n",
    "def to_yolo(x, y, w, h):\n",
    "    \"\"\"\n",
    "    Convert bounding box coordinates to YOLO format\n",
    "    \"\"\"\n",
    "    x_center = (x + w / 2) / IMG_SIZE\n",
    "    y_center = (y + h / 2) / IMG_SIZE\n",
    "    norm_w = w / IMG_SIZE\n",
    "    norm_h = h / IMG_SIZE\n",
    "    \n",
    "    return x_center, y_center, norm_w, norm_h\n",
    "\n",
    "\n",
    "def generate_dataset(num_images=5000, weeds_per_image=(1, 3)):\n",
    "    \"\"\"\n",
    "    Generate dataset with only Chinese apple images\n",
    "    \n",
    "    Args:\n",
    "        num_images: Number of images to generate\n",
    "        weeds_per_image: Tuple of (min, max) weeds per image\n",
    "    \"\"\"\n",
    "    # Load only Chinese apple images\n",
    "    chinee_apples = load_chinee_apple_images()\n",
    "    backgrounds = load_backgrounds()\n",
    "    \n",
    "    if len(chinee_apples) == 0:\n",
    "        print(\"Error: No Chinese apple images found!\")\n",
    "        print(f\"Please check the path: {CHINEE_APPLE_DIR}\")\n",
    "        return\n",
    "    \n",
    "    if len(backgrounds) == 0:\n",
    "        print(\"Error: No background images found!\")\n",
    "        return\n",
    "    \n",
    "    print(f\"Generating {num_images} images with only Chinese apple weeds...\")\n",
    "    \n",
    "    for i in tqdm(range(num_images), desc=\"Generating images\"):\n",
    "        # Select random background\n",
    "        bg = random.choice(backgrounds).copy()\n",
    "        \n",
    "        # Determine number of weeds for this image (1-3 as requested)\n",
    "        num_weeds = random.randint(weeds_per_image[0], weeds_per_image[1])\n",
    "        \n",
    "        labels = []\n",
    "        \n",
    "        # Place weeds on background\n",
    "        for _ in range(num_weeds):\n",
    "            # Select random Chinese apple image\n",
    "            weed, class_id = random.choice(chinee_apples)\n",
    "            \n",
    "            # Apply augmentations\n",
    "            weed = augment_weed(weed)\n",
    "            \n",
    "            # Paste onto background\n",
    "            bg, x, y, w, h = paste_weed(bg, weed)\n",
    "            \n",
    "            # Convert to YOLO format\n",
    "            x_center, y_center, norm_w, norm_h = to_yolo(x, y, w, h)\n",
    "            \n",
    "            # Add to labels (class_id is always 0 for Chinese apple)\n",
    "            labels.append(f\"0 {x_center:.6f} {y_center:.6f} {norm_w:.6f} {norm_h:.6f}\")\n",
    "        \n",
    "        # Save image\n",
    "        img_name = f\"chine_apple_{i:06d}.jpg\"\n",
    "        cv2.imwrite(os.path.join(OUT_IMG, img_name), bg)\n",
    "        \n",
    "        # Save labels\n",
    "        label_path = os.path.join(OUT_LABEL, img_name.replace(\".jpg\", \".txt\"))\n",
    "        with open(label_path, \"w\") as f:\n",
    "            f.write(\"\\n\".join(labels))\n",
    "    \n",
    "    print(f\"\\nDataset generation complete!\")\n",
    "    print(f\"Images saved to: {OUT_IMG}\")\n",
    "    print(f\"Labels saved to: {OUT_LABEL}\")\n",
    "    print(f\"Total images generated: {num_images}\")\n",
    "    \n",
    "    # Print statistics\n",
    "    total_weeds_placed = num_images * (weeds_per_image[0] + weeds_per_image[1]) // 2\n",
    "    print(f\"Estimated total Chinese apple instances: ~{total_weeds_placed}\")\n",
    "\n",
    "\n",
    "def verify_dataset():\n",
    "    \"\"\"\n",
    "    Quick verification of generated dataset\n",
    "    \"\"\"\n",
    "    print(\"\\nVerifying generated dataset...\")\n",
    "    \n",
    "    image_files = [f for f in os.listdir(OUT_IMG) if f.endswith('.jpg')]\n",
    "    label_files = [f for f in os.listdir(OUT_LABEL) if f.endswith('.txt')]\n",
    "    \n",
    "    print(f\"Number of images: {len(image_files)}\")\n",
    "    print(f\"Number of labels: {len(label_files)}\")\n",
    "    \n",
    "    # Check if counts match\n",
    "    if len(image_files) != len(label_files):\n",
    "        print(f\"WARNING: Mismatch between images ({len(image_files)}) and labels ({len(label_files)})\")\n",
    "    \n",
    "    # Check a few random labels\n",
    "    if len(label_files) > 0:\n",
    "        sample_label = random.choice(label_files)\n",
    "        label_path = os.path.join(OUT_LABEL, sample_label)\n",
    "        \n",
    "        with open(label_path, 'r') as f:\n",
    "            content = f.read().strip()\n",
    "            \n",
    "            if content:\n",
    "                lines = content.split('\\n')\n",
    "                num_weeds = len(lines)\n",
    "                print(f\"\\nSample label file '{sample_label}' contains {num_weeds} weed(s)\")\n",
    "                print(f\"First annotation: {lines[0]}\")\n",
    "                \n",
    "                # Verify format (should be: class x_center y_center width height)\n",
    "                first_line_parts = lines[0].split()\n",
    "                if len(first_line_parts) == 5:\n",
    "                    print(f\"  Class: {first_line_parts[0]}\")\n",
    "                    print(f\"  Format: Valid YOLO format\")\n",
    "                else:\n",
    "                    print(f\"  WARNING: Invalid YOLO format - expected 5 values, got {len(first_line_parts)}\")\n",
    "            else:\n",
    "                print(f\"\\nSample label file '{sample_label}' is EMPTY (no weeds in this image)\")\n",
    "    \n",
    "    # Check a sample image to ensure it exists\n",
    "    if len(image_files) > 0:\n",
    "        sample_image = random.choice(image_files)\n",
    "        img_path = os.path.join(OUT_IMG, sample_image)\n",
    "        img = cv2.imread(img_path)\n",
    "        if img is not None:\n",
    "            print(f\"\\nSample image '{sample_image}' loaded successfully - shape: {img.shape}\")\n",
    "        else:\n",
    "            print(f\"\\nWARNING: Could not load sample image '{sample_image}'\")\n",
    "    \n",
    "    # Summary\n",
    "    print(f\"\\nDataset summary:\")\n",
    "    print(f\"  Total images: {len(image_files)}\")\n",
    "    print(f\"  Total labels: {len(label_files)}\")\n",
    "    \n",
    "    # Check if any label files are empty\n",
    "    empty_labels = 0\n",
    "    for label_file in label_files[:100]:  # Check first 100\n",
    "        with open(os.path.join(OUT_LABEL, label_file), 'r') as f:\n",
    "            if not f.read().strip():\n",
    "                empty_labels += 1\n",
    "    \n",
    "    if empty_labels > 0:\n",
    "        print(f\"  WARNING: {empty_labels} empty label files found (images with no weeds)\")\n",
    "    else:\n",
    "        print(f\"  All checked label files contain annotations\")\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    # Configuration\n",
    "    NUM_IMAGES = 1000  # Number of images to generate\n",
    "    MIN_WEEDS = 1       # Minimum weeds per image\n",
    "    MAX_WEEDS = 3       # Maximum weeds per image\n",
    "    \n",
    "    print(\"=\"*50)\n",
    "    print(\"CHINESE APPLE DATASET GENERATOR\")\n",
    "    print(\"=\"*50)\n",
    "    print(f\"Output directory: {OUT_IMG}\")\n",
    "    print(f\"Number of images: {NUM_IMAGES}\")\n",
    "    print(f\"Weeds per image: {MIN_WEEDS}-{MAX_WEEDS}\")\n",
    "    print(\"=\"*50)\n",
    "    \n",
    "    # Generate dataset\n",
    "    generate_dataset(\n",
    "        num_images=NUM_IMAGES,\n",
    "        weeds_per_image=(MIN_WEEDS, MAX_WEEDS)\n",
    "    )\n",
    "    \n",
    "    # Verify\n",
    "    verify_dataset()"
   ]
