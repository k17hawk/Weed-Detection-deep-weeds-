    "import os\n",
    "import pandas as pd\n",
    "import shutil\n",
    "from pathlib import Path\n",
    "\n",
    "# Define paths\n",
    "csv_path = '../artifacts/data_ingestion/normalized/v_20260307_192121_5a0b6671da93a189/'\n",
    "train_images = os.path.join(csv_path, 'images', 'train')\n",
    "train_csv = os.path.join(csv_path, 'labels', 'train.csv')\n",
    "\n",
    "# Define species mapping\n",
    "SPECIES_MAP = {\n",
    "    0: 'Chinee Apple', \n",
    "    1: 'Lantana', \n",
    "    2: 'Parkinsonia',\n",
    "    3: 'Parthenium', \n",
    "    4: 'Prickly acacia', \n",
    "    5: 'Rubber Vine',\n",
    "    6: 'Siam weed', \n",
    "    7: 'Snake weed', \n",
    "    8: 'Negative',\n",
    "}\n",
    "\n",
    "# Create output directory for organized species folders\n",
    "output_dir = os.path.join(csv_path, 'organized_by_species', 'train')\n",
    "os.makedirs(output_dir, exist_ok=True)\n",
    "\n",
    "# Read the training CSV\n",
    "df = pd.read_csv(train_csv)\n",
    "\n",
    "# Create folders for each species\n",
    "for species_id, species_name in SPECIES_MAP.items():\n",
    "    species_folder = os.path.join(output_dir, species_name)\n",
    "    os.makedirs(species_folder, exist_ok=True)\n",
    "    print(f\"Created folder: {species_folder}\")\n",
    "\n",
    "# Copy images to their respective species folders\n",
    "print(\"\\nCopying images...\")\n",
    "copied_count = 0\n",
    "error_count = 0\n",
    "\n",
    "for index, row in df.iterrows():\n",
    "    filename = row['Filename']\n",
    "    species_id = row['Label']\n",
    "    species_name = SPECIES_MAP.get(species_id, 'Unknown')\n",
    "    \n",
    "    # Source path\n",
    "    src_path = os.path.join(train_images, filename)\n",
    "    \n",
    "    # Destination path\n",
    "    dst_folder = os.path.join(output_dir, species_name)\n",
    "    dst_path = os.path.join(dst_folder, filename)\n",
    "    \n",
    "    # Check if source file exists\n",
    "    if os.path.exists(src_path):\n",
    "        try:\n",
    "            shutil.copy2(src_path, dst_path)  # copy2 preserves metadata\n",
    "            copied_count += 1\n",
    "            if copied_count % 100 == 0:  # Print progress every 100 images\n",
    "                print(f\"Copied {copied_count} images...\")\n",
    "        except Exception as e:\n",
    "            print(f\"Error copying {filename}: {e}\")\n",
    "            error_count += 1\n",
    "    else:\n",
    "        print(f\"Warning: Source file not found: {src_path}\")\n",
    "        error_count += 1\n",
    "\n",
    "print(f\"\\nCompleted!\")\n",
    "print(f\"Successfully copied: {copied_count} images\")\n",
    "print(f\"Errors/Skipped: {error_count} images\")\n",
    "print(f\"Total images in CSV: {len(df)}\")\n",
    "\n",
    "# Optional: Show distribution of images per species\n",
    "print(\"\\nDistribution of images per species:\")\n",
    "species_distribution = df['Label'].value_counts().sort_index()\n",
    "for species_id, count in species_distribution.items():\n",
    "    species_name = SPECIES_MAP.get(species_id, 'Unknown')\n",
    "    print(f\"{species_name}: {count} images\")"
   ]
  },
