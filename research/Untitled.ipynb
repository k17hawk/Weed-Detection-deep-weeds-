    "import os\n",
    "from PIL import Image\n",
    "from pathlib import Path\n",
    "\n",
    "def process_images_for_yolo(input_dir, output_dir, start_number=1, max_size_mb=2):\n",
    "    \"\"\"\n",
    "    Process images for YOLO model training\n",
    "    \n",
    "    Args:\n",
    "        input_dir: Directory containing input images\n",
    "        output_dir: Directory to save processed images\n",
    "        start_number: Starting number for naming (chine_apple_1.jpg, chine_apple_2.jpg, etc.)\n",
    "        max_size_mb: Maximum file size in MB\n",
    "    \"\"\"\n",
    "    \n",
    "    # Create output directory\n",
    "    os.makedirs(output_dir, exist_ok=True)\n",
    "    \n",
    "    # Supported formats\n",
    "    image_extensions = ('.jpg', '.jpeg', '.png', '.bmp', '.tiff', '.webp')\n",
    "    \n",
    "    # Get all images\n",
    "    images = []\n",
    "    for ext in image_extensions:\n",
    "        images.extend(Path(input_dir).glob(f'*{ext}'))\n",
    "        images.extend(Path(input_dir).glob(f'*{ext.upper()}'))\n",
    "    \n",
    "    # Remove duplicates and sort\n",
    "    images = sorted(list(set(images)))\n",
    "    \n",
    "    print(f\"Found {len(images)} images to process\")\n",
    "    \n",
    "    for idx, image_path in enumerate(images, start=start_number):\n",
    "        try:\n",
    "            # Output filename\n",
    "            output_filename = f\"chine_apple_new1__{idx}.jpg\"\n",
    "            output_path = os.path.join(output_dir, output_filename)\n",
    "            \n",
    "            # Open and process image\n",
    "            img = Image.open(image_path)\n",
    "            \n",
    "            # Convert to RGB (required for JPG)\n",
    "            if img.mode != 'RGB':\n",
    "                img = img.convert('RGB')\n",
    "            \n",
    "            # Save temporarily\n",
    "            temp_path = output_path + '.temp'\n",
    "            img.save(temp_path, 'JPEG', quality=95, optimize=True)\n",
    "            \n",
    "            # Check file size\n",
    "            file_size = os.path.getsize(temp_path) / (1024 * 1024)  # Convert to MB\n",
    "            \n",
    "            if file_size > max_size_mb:\n",
    "                print(f\"Compressing {image_path.name} ({file_size:.2f}MB)...\")\n",
    "                \n",
    "                # Progressive compression\n",
    "                quality = 85\n",
    "                while quality >= 10:\n",
    "                    img.save(temp_path, 'JPEG', quality=quality, optimize=True)\n",
    "                    new_size = os.path.getsize(temp_path) / (1024 * 1024)\n",
    "                    \n",
    "                    if new_size <= max_size_mb:\n",
    "                        print(f\"  Compressed to {new_size:.2f}MB (quality: {quality})\")\n",
    "                        break\n",
    "                    \n",
    "                    quality -= 5\n",
    "                \n",
    "                # If still too large, apply maximum compression\n",
    "                if quality < 10:\n",
    "                    img.save(temp_path, 'JPEG', quality=10, optimize=True)\n",
    "                    final_size = os.path.getsize(temp_path) / (1024 * 1024)\n",
    "                    print(f\"  Maximum compression applied: {final_size:.2f}MB\")\n",
    "            \n",
    "            # Move to final location\n",
    "            os.replace(temp_path, output_path)\n",
    "            print(f\"Saved: {output_filename}\")\n",
    "            \n",
    "        except Exception as e:\n",
    "            print(f\"Error processing {image_path.name}: {e}\")\n",
    "    \n",
    "    print(f\"\\nProcessing complete! Images saved in: {output_dir}\")\n",
    "\n",
    "# Usage\n",
    "if __name__ == \"__main__\":\n",
    "    # Change these paths according to your needs\n",
    "    input_directory = \"/home/lang-chain/Documents/apple_extra_20:14\"  \n",
    "    output_directory = \"./processed_images_apple_extra_20:14\"  # Where to save processed images\n",
    "    \n",
    "    process_images_for_yolo(\n",
    "        input_dir=input_directory,\n",
    "        output_dir=output_directory,\n",
    "        start_number=1,  # Start naming from 1\n",
    "        max_size_mb=2.0  # Compress if larger than 2MB\n",
    "    )"
   ]
