    "import json\n",
    "import os\n",
    "import shutil\n",
    "from tqdm import tqdm\n",
    "\n",
    "def coco_to_yolo_simple(coco_json_path, images_dir, output_dir):\n",
    "    \"\"\"\n",
    "    Simple COCO to YOLO converter\n",
    "    \n",
    "    Args:\n",
    "        coco_json_path: Path to COCO JSON file\n",
    "        images_dir: Directory containing the images\n",
    "        output_dir: Output directory for YOLO format\n",
    "    \"\"\"\n",
    "    \n",
    "    # Create output directories\n",
    "    img_out_dir = os.path.join(output_dir, 'images')\n",
    "    label_out_dir = os.path.join(output_dir, 'labels')\n",
    "    os.makedirs(img_out_dir, exist_ok=True)\n",
    "    os.makedirs(label_out_dir, exist_ok=True)\n",
    "    \n",
    "    # Load COCO JSON\n",
    "    with open(coco_json_path, 'r') as f:\n",
    "        coco = json.load(f)\n",
    "    \n",
    "    print(f\"Loaded COCO with {len(coco['images'])} images and {len(coco['annotations'])} annotations\")\n",
    "    \n",
    "    # Check if categories exist\n",
    "    if 'categories' in coco and coco['categories']:\n",
    "        category_map = {cat['id']: idx for idx, cat in enumerate(coco['categories'])}\n",
    "        print(f\"Category mapping: {category_map}\")\n",
    "    else:\n",
    "        print(\"No categories found in COCO file\")\n",
    "        category_map = {}\n",
    "    \n",
    "    # Group annotations by image\n",
    "    image_annotations = {}\n",
    "    for ann in coco['annotations']:\n",
    "        img_id = ann['image_id']\n",
    "        if img_id not in image_annotations:\n",
    "            image_annotations[img_id] = []\n",
    "        image_annotations[img_id].append(ann)\n",
    "    \n",
    "    # Process each image\n",
    "    successful_conversions = 0\n",
    "    failed_conversions = 0\n",
    "    \n",
    "    for img_info in tqdm(coco['images'], desc=\"Converting\"):\n",
    "        try:\n",
    "            img_id = img_info['id']\n",
    "            img_filename = img_info['file_name']\n",
    "            img_width = float(img_info['width'])  # Convert to float\n",
    "            img_height = float(img_info['height'])  # Convert to float\n",
    "            \n",
    "            # Source image path\n",
    "            src_img_path = os.path.join(images_dir, img_filename)\n",
    "            \n",
    "            if not os.path.exists(src_img_path):\n",
    "                print(f\"Warning: Image not found: {src_img_path}\")\n",
    "                failed_conversions += 1\n",
    "                continue\n",
    "            \n",
    "            # Destination paths\n",
    "            dst_img_path = os.path.join(img_out_dir, img_filename)\n",
    "            \n",
    "            # Create label filename (handle different image extensions)\n",
    "            base_filename = os.path.splitext(img_filename)[0]\n",
    "            dst_label_path = os.path.join(label_out_dir, f\"{base_filename}.txt\")\n",
    "            \n",
    "            # Copy image\n",
    "            shutil.copy2(src_img_path, dst_img_path)\n",
    "            \n",
    "            # Create label file\n",
    "            with open(dst_label_path, 'w') as f:\n",
    "                if img_id in image_annotations:\n",
    "                    for ann in image_annotations[img_id]:\n",
    "                        # COCO bbox: [x, y, width, height]\n",
    "                        # Convert all bbox values to float\n",
    "                        bbox = [float(x) for x in ann['bbox']]\n",
    "                        \n",
    "                        # Convert to YOLO format\n",
    "                        x_center = (bbox[0] + bbox[2]/2) / img_width\n",
    "                        y_center = (bbox[1] + bbox[3]/2) / img_height\n",
    "                        width = bbox[2] / img_width\n",
    "                        height = bbox[3] / img_height\n",
    "                        \n",
    "                        # Ensure values are within [0, 1] range\n",
    "                        x_center = max(0, min(1, x_center))\n",
    "                        y_center = max(0, min(1, y_center))\n",
    "                        width = max(0, min(1, width))\n",
    "                        height = max(0, min(1, height))\n",
    "                        \n",
    "                        # Get class ID (mapped to 0 if you only want chinee apple)\n",
    "                        class_id = 0  # Set to 0 for chinee apple\n",
    "                        \n",
    "                        # Write YOLO format line\n",
    "                        f.write(f\"{class_id} {x_center:.6f} {y_center:.6f} {width:.6f} {height:.6f}\\n\")\n",
    "            \n",
    "            successful_conversions += 1\n",
    "            \n",
    "        except Exception as e:\n",
    "            print(f\"Error processing image {img_info.get('file_name', 'unknown')}: {e}\")\n",
    "            failed_conversions += 1\n",
    "            continue\n",
    "    \n",
    "    print(f\"\\n✅ Conversion complete!\")\n",
    "    print(f\"Successfully converted: {successful_conversions} images\")\n",
    "    print(f\"Failed conversions: {failed_conversions} images\")\n",
    "    print(f\"Images saved to: {img_out_dir}\")\n",
    "    print(f\"Labels saved to: {label_out_dir}\")\n",
    "    \n",
    "    # Create a simple data.yaml\n",
    "    yaml_path = os.path.join(output_dir, 'data.yaml')\n",
    "    with open(yaml_path, 'w') as f:\n",
    "        f.write(f\"\"\"# Dataset\n",
    "path: {os.path.abspath(output_dir)}\n",
    "train: images\n",
    "val: images\n",
    "\n",
    "# Classes\n",
    "nc: 1\n",
    "names: ['chinee_apple']\n",
    "\"\"\")\n",
    "    print(f\"Created data.yaml: {yaml_path}\")\n",
    "    \n",
    "    # Print statistics\n",
    "    print(\"\\n📊 Statistics:\")\n",
    "    total_labels = 0\n",
    "    for label_file in os.listdir(label_out_dir):\n",
    "        if label_file.endswith('.txt'):\n",
    "            with open(os.path.join(label_out_dir, label_file), 'r') as f:\n",
    "                content = f.read().strip()\n",
    "                if content:\n",
    "                    total_labels += len(content.split('\\n'))\n",
    "    \n",
    "    print(f\"Total annotations created: {total_labels}\")\n",
    "\n",
    "# Also create a verification function\n",
    "def verify_conversion(output_dir):\n",
    "    \"\"\"Verify the converted dataset\"\"\"\n",
    "    print(\"\\n\" + \"=\"*50)\n",
    "    print(\"VERIFYING CONVERSION\")\n",
    "    print(\"=\"*50)\n",
    "    \n",
    "    images_dir = os.path.join(output_dir, 'images')\n",
    "    labels_dir = os.path.join(output_dir, 'labels')\n",
    "    \n",
    "    if not os.path.exists(images_dir) or not os.path.exists(labels_dir):\n",
    "        print(\"❌ Output directories not found!\")\n",
    "        return\n",
    "    \n",
    "    images = [f for f in os.listdir(images_dir) if f.endswith(('.jpg', '.jpeg', '.png'))]\n",
    "    labels = [f for f in os.listdir(labels_dir) if f.endswith('.txt')]\n",
    "    \n",
    "    print(f\"Images found: {len(images)}\")\n",
    "    print(f\"Labels found: {len(labels)}\")\n",
    "    \n",
    "    # Check if counts match\n",
    "    image_basenames = set([os.path.splitext(f)[0] for f in images])\n",
    "    label_basenames = set([os.path.splitext(f)[0] for f in labels])\n",
    "    \n",
    "    missing_labels = image_basenames - label_basenames\n",
    "    missing_images = label_basenames - image_basenames\n",
    "    \n",
    "    if missing_labels:\n",
    "        print(f\"⚠️  Warning: {len(missing_labels)} images missing labels\")\n",
    "        print(f\"   First 5: {list(missing_labels)[:5]}\")\n",
    "    \n",
    "    if missing_images:\n",
    "        print(f\"⚠️  Warning: {len(missing_images)} labels missing images\")\n",
    "        print(f\"   First 5: {list(missing_images)[:5]}\")\n",
    "    \n",
    "    # Check a sample label file\n",
    "    if labels:\n",
    "        sample_label = labels[0]\n",
    "        label_path = os.path.join(labels_dir, sample_label)\n",
    "        with open(label_path, 'r') as f:\n",
    "            content = f.read().strip()\n",
    "            if content:\n",
    "                lines = content.split('\\n')\n",
    "                print(f\"\\nSample label ({sample_label}):\")\n",
    "                print(f\"  Number of annotations: {len(lines)}\")\n",
    "                print(f\"  First annotation: {lines[0]}\")\n",
    "                \n",
    "                # Verify format\n",
    "                first_line_parts = lines[0].split()\n",
    "                if len(first_line_parts) == 5:\n",
    "                    print(f\"  ✅ Valid YOLO format\")\n",
    "                    print(f\"     Class: {first_line_parts[0]}\")\n",
    "                    print(f\"     x_center: {float(first_line_parts[1]):.3f}\")\n",
    "                    print(f\"     y_center: {float(first_line_parts[2]):.3f}\")\n",
    "                    print(f\"     width: {float(first_line_parts[3]):.3f}\")\n",
    "                    print(f\"     height: {float(first_line_parts[4]):.3f}\")\n",
    "                else:\n",
    "                    print(f\"  ❌ Invalid format: expected 5 values, got {len(first_line_parts)}\")\n",
    "            else:\n",
    "                print(f\"\\nSample label ({sample_label}) is empty\")\n",
    "    \n",
    "    print(\"\\n\" + \"=\"*50)\n",
    "\n",
    "# Usage\n",
    "if __name__ == \"__main__\":\n",
    "    # Update these paths\n",
    "    coco_json_path = '/home/lang-chain/Downloads/My First Project.v1-2026-03-15-18-12.coco/train/_annotations.coco.json'\n",
